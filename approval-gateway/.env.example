# ============================================================
# Approval Gateway — Configuration
# ============================================================
# Copy to .env and fill in your values:
#   cp .env.example .env
#
# Then start the server:
#   python3 -m uvicorn approval_server:app --host 127.0.0.1 --port 5004
#
# Or via systemd (see approval_server.py header for unit file).
# ============================================================

# --- Public URL (used in SMS links) ---
# If behind Nginx, use your domain + location prefix:
#   GATEWAY_URL=https://cslogixdispatch.com/approve
# If testing locally:
#   GATEWAY_URL=http://localhost:5004
GATEWAY_URL=http://localhost:5004

# --- SMS Notification ---
# Format: 10-digit-number@carrier-gateway
#
# Carrier lookup table:
#   T-Mobile ........... 5551234567@tmomail.net
#   AT&T ............... 5551234567@txt.att.net
#   Verizon ............ 5551234567@vtext.com
#   Sprint/T-Mobile .... 5551234567@messaging.sprintpcs.com
#   Google Fi .......... 5551234567@msg.fi.google.com
#   US Cellular ........ 5551234567@email.uscc.net
#   Cricket ............ 5551234567@sms.cricketwireless.net
#   Boost Mobile ....... 5551234567@sms.myboostmobile.com
#   Metro by T-Mobile .. 5551234567@mymetropcs.com
#   Mint Mobile ........ 5551234567@tmomail.net (uses T-Mobile)
#
SMS_EMAIL=
SMTP_USER=
SMTP_PASSWORD=
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587

# --- API Auth (optional) ---
# If set, the bash script must pass this as Bearer token.
# Generate one: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
APPROVAL_API_TOKEN=

# ============================================================
# Setup Steps
# ============================================================
#
# 1. Install deps (if not already present):
#      pip3 install fastapi uvicorn python-dotenv --break-system-packages
#
# 2. Gmail App Password (for SMS):
#    - Go to https://myaccount.google.com/apppasswords
#    - Generate an app password for "Mail"
#    - Paste it as SMTP_PASSWORD above
#    - Set SMTP_USER to your Gmail address
#    - Set SMS_EMAIL to your phone number@carrier gateway
#
# 3. Nginx proxy (recommended):
#    Add to your nginx server block:
#
#      location /approve/ {
#          proxy_pass http://127.0.0.1:5004/;
#          proxy_set_header Host $host;
#          proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
#          proxy_set_header X-Forwarded-Proto $scheme;
#      }
#
#    Then set GATEWAY_URL=https://cslogixdispatch.com/approve
#    Run: nginx -t && systemctl reload nginx
#
# 4. Systemd service:
#
#      sudo tee /etc/systemd/system/csl-approve.service << 'EOF'
#      [Unit]
#      Description=Approval Gateway
#      After=network.target
#      [Service]
#      ExecStart=/usr/bin/python3 -m uvicorn approval_server:app --host 127.0.0.1 --port 5004
#      WorkingDirectory=/root/csl-bot/approval-gateway
#      EnvironmentFile=/root/csl-bot/approval-gateway/.env
#      Restart=on-failure
#      [Install]
#      WantedBy=multi-user.target
#      EOF
#
#      sudo systemctl daemon-reload
#      sudo systemctl enable --now csl-approve
#
# 5. Bash wrapper setup:
#    - Copy claude-approve.sh to /usr/local/bin/ (or add to PATH)
#    - chmod +x claude-approve.sh
#    - Set GATEWAY_INTERNAL=http://localhost:5004 in your shell profile
#      (or the script defaults to localhost:5004)
#
# 6. Daily workflow:
#      cd /root/csl-bot
#      claude-approve.sh prepare "my-feature"
#      # ... let Claude Code work on the staging branch ...
#      claude-approve.sh submit "Add carrier tracking for XYZ"
#      # → SMS arrives on your phone
#      # → Tap link, review diff, approve or reject
#      # → Script auto-merges on approve, reports rejection comment on reject
# ============================================================
