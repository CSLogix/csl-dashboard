# CSL Document Tracker — Environment Configuration
# Copy this file to .env and fill in your values.

# --- Gmail API ---
GMAIL_CREDENTIALS_PATH=credentials.json
GMAIL_TOKEN_PATH=token.json
GMAIL_MONITORED_ACCOUNT=csl.doctracker@gmail.com

# --- Google Sheets ---
GOOGLE_SHEETS_ID=your-sheet-id-here
GOOGLE_SHEETS_CREDENTIALS_PATH=/root/csl-credentials.json
SHEET_TAB_NAME=Active Loads
SHEET_SYNC_INTERVAL_MINUTES=5

# Optional: column headers for customer metadata
# SHEET_CUSTOMER_REF_COLUMN=Customer Ref
# SHEET_CUSTOMER_NAME_COLUMN=Customer

# --- PostgreSQL ---
DB_HOST=localhost
DB_PORT=5432
DB_NAME=csl_doc_tracker
DB_USER=csl_admin
DB_PASSWORD=changeme

# --- Document Storage ---
DOCUMENT_STORAGE_PATH=/opt/csl-docs/files

# --- Dashboard ---
DASHBOARD_HOST=0.0.0.0
DASHBOARD_PORT=8080

# --- Polling ---
SCAN_INTERVAL_SECONDS=120

# --- Logging ---
LOG_LEVEL=INFO
LOG_FILE=csl_doc_tracker.log
